# Environment variables — set these in Railway dashboard

# PostgreSQL connection string (Railway Postgres plugin provides this automatically)
DATABASE_URL="postgresql://user:password@localhost:5432/renovateflow"

# Session encryption secret (generate with: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-random-32-char-string-minimum"

# Public app URL (your Railway domain, e.g. https://renovateflow.up.railway.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Anthropic API key for enhanced contract parsing
# Note: Claude Pro/Max subscription does NOT include API access.
# Without this key, the built-in rule-based parser handles standard milestone tables.
# ANTHROPIC_API_KEY="sk-ant-..."

# Upload directory (Railway volume mount path)
UPLOAD_DIR="/app/uploads"
